# Car2LEGO Environment Variables
# Copy this file to .env and fill in your values

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional
REBRICKABLE_API_KEY=
BRICKLINK_API_KEY=
BRICKLINK_API_SECRET=

# Studio paths (Windows only — for desktop automation)
STUDIO_PATH=D:\lego\Studio 2.0\Studio.exe
PARTDESIGNER_PATH=D:\lego\Studio 2.0\patcher2\Patcher.exe

# Database
DATABASE_URL=postgresql+asyncpg://car2lego:car2lego@localhost:5432/car2lego
REDIS_URL=redis://localhost:6379/0
STORAGE_PATH=./storage
DEBUG=true
